<h1>Amazon Product Scraper - Saved Data</h1>

<div style="margin-bottom: 20px;">
  <%= link_to "New Scrape", new_amazon_product_path, class: "button" %>
</div>

<% if @amazon_urls.any? %>
  <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <thead>
      <tr style="background-color: #f5f5f5;">
        <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">URL</th>
        <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Product Name</th>
        <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">MRP</th>
        <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Actual Price</th>
        <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Discount</th>
        <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Price</th>
        <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Tax</th>
        <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Scraped At</th>
        <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @amazon_urls.each do |amazon_url| %>
        <% amazon_url.amazon_products.order(created_at: :desc).each do |product| %>
          <tr>
            <td style="border: 1px solid #ddd; padding: 8px;">
              <a href="<%= amazon_url.url %>" target="_blank" style="word-break: break-all;">
                <%= truncate(amazon_url.url, length: 50) %>
              </a>
            </td>
            <td style="border: 1px solid #ddd; padding: 8px;"><%= product.name %></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><%= product.mrp %></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><%= product.actual_price %></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><%= product.discount %></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><%= product.price %></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><%= product.tax %></td>
            <td style="border: 1px solid #ddd; padding: 8px;"><%= product.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td style="border: 1px solid #ddd; padding: 8px;">
              <a href="<%= delete_amazon_url_path(amazon_url) %>" 
                 onclick="return confirm('Are you sure you want to delete this data? This action cannot be undone.');"
                 style="padding: 4px 8px; background-color: #dc3545; color: white; text-decoration: none; border-radius: 3px; font-size: 12px;">
                Delete
              </a>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No scraped data found. <%= link_to "Start scraping", new_amazon_product_path %> to see data here.</p>
<% end %> 